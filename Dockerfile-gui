# CoLinux Lite GUI — Development & Testing Container
# Simulates the full Alpine-based CoLinux GUI environment.
# Includes cage/sway/foot Wayland stack for syntax validation and basic testing.
#
# NOTE: cage/sway will NOT work inside Docker without GPU passthrough.
#       This Dockerfile validates that all scripts, configs, and packages
#       install correctly. For actual GUI testing, use QEMU or bare metal.
#
# Usage:
#   docker build -t colinux-lite-gui -f Dockerfile-gui .
#   docker run -it --rm colinux-lite-gui bash
#
# With GPU passthrough (for actual GUI testing):
#   docker run -it --rm \
#     --device /dev/dri \
#     -e XDG_RUNTIME_DIR=/run/user/1000 \
#     -e WAYLAND_DISPLAY=wayland-1 \
#     colinux-lite-gui

FROM alpine:3.21

LABEL maintainer="CoLinux Project"
LABEL description="CoLinux Lite GUI development/test environment (cage + sway + foot)"
LABEL version="0.1.0"

# ── Install core packages (same as lite edition) ─────────────────────────────
RUN apk add --no-cache \
    alpine-base \
    linux-lts-doc \
    bash \
    coreutils \
    util-linux \
    eudev \
    eudev-rule-generator \
    doas \
    sudo \
    tmux \
    git \
    openssh-client \
    curl \
    wget \
    ca-certificates \
    jq \
    yq \
    ripgrep \
    fd \
    fzf \
    nano \
    python3 \
    parted \
    gptfdisk \
    e2fsprogs \
    dosfstools \
    exfatprogs \
    btrfs-progs \
    xfsprogs \
    cryptsetup \
    lvm2 \
    mdadm \
    rsync \
    smartmontools \
    pciutils \
    usbutils \
    file \
    iw \
    openssl \
    tar \
    gzip \
    xz \
    shadow \
    procps \
    dbus \
    dialog \
    xkb-utils

# ── Install GUI/Wayland packages ─────────────────────────────────────────────
RUN apk add --no-cache \
    cage \
    sway \
    foot \
    seatd \
    mesa-dri-gallium \
    mesa-gl \
    font-dejavu \
    wlr-randr \
    grim \
    slurp \
    libinput-libs \
    libinput-tools \
    wl-clipboard

# ── Install network packages (from shared) ───────────────────────────────────
RUN apk add --no-cache \
    iwd \
    wpa_supplicant \
    dhcpcd \
    wireless-tools \
    iw \
    crda \
    rfkill \
    ethtool

# ── Install Camoufox dependencies (from shared) ──────────────────────────────
RUN apk add --no-cache \
    py3-pip \
    py3-requests \
    py3-cryptography \
    py3-setuptools \
    gcc \
    g++ \
    musl-dev \
    make \
    pkgconfig \
    sqlite-dev \
    libffi-dev

# ── Create runtime directories ───────────────────────────────────────────────
RUN mkdir -p /run/codex \
    /run/seatd \
    /run/user/1000 \
    /persist/config/wifi \
    /persist/config/packages \
    /persist/config/postinstall \
    /persist/data \
    /persist/logs \
    /persist/backups \
    /persist/ssh \
    /persist/state \
    /workspace \
    /workspace/bin \
    /mnt/disks/by-label \
    /mnt/disks/by-uuid \
    /mnt/disks/by-device \
    /var/cache/apk \
    /etc/default \
    /etc/sway \
    /etc/cage \
    /etc/udev/rules.d \
    /opt/camoufox \
    /usr/local/lib/colinux

# ── Create codex user with proper group membership ───────────────────────────
RUN adduser -D -s /bin/bash -h /home/codex codex && \
    addgroup -S seatd 2>/dev/null || true && \
    addgroup codex seatd 2>/dev/null || true && \
    addgroup codex video 2>/dev/null || true && \
    addgroup codex input 2>/dev/null || true && \
    addgroup codex audio 2>/dev/null || true && \
    echo "codex ALL=(root) NOPASSWD: /usr/local/bin/codex-disk-inventory, /usr/local/bin/codex-network, /usr/local/bin/codex-backup, /usr/local/bin/codex-restore, /usr/local/bin/codex-update, /usr/local/bin/codex-shell, /usr/local/bin/codex-shell-gui, /usr/local/bin/codexctl, /usr/local/bin/codex-logs, /usr/local/bin/codex-mount-rw, /usr/local/bin/codex-mount-ro, /usr/local/bin/codex-usb-persist, /usr/local/sbin/codex-wifi-wizard, /usr/local/sbin/codex-network-stack" > /etc/sudoers.d/codex && \
    chown -R codex:codex /home/codex /workspace /persist

# ── Install doas config ──────────────────────────────────────────────────────
RUN echo "permit nopass :codex as root cmd /usr/local/bin/codex-wifi-wizard" > /etc/doas.conf && \
    echo "permit nopass :codex as root cmd /usr/local/sbin/codex-network-stack" >> /etc/doas.conf && \
    echo "permit nopass :codex as root cmd /usr/local/sbin/install-camoufox" >> /etc/doas.conf && \
    chmod 640 /etc/doas.conf

# ── Install codex-shell.conf ─────────────────────────────────────────────────
COPY profiles/alpine/overlay-gui/etc/codex-shell.conf /etc/codex-shell.conf

# ── Install codex tools from lite overlay ────────────────────────────────────
COPY profiles/alpine/overlay/usr/local/bin/ /usr/local/bin/
RUN chmod +x /usr/local/bin/codex-* /usr/local/bin/codexctl 2>/dev/null || true

# ── Install GUI overlay files ────────────────────────────────────────────────
# codex-shell-gui (the main GUI shell)
COPY profiles/alpine/overlay-gui/usr/local/bin/codex-shell-gui /usr/local/bin/codex-shell-gui
RUN chmod +x /usr/local/bin/codex-shell-gui

# codex-clipboard (Wayland clipboard helper)
COPY profiles/alpine/overlay-gui/usr/local/bin/codex-clipboard /usr/local/bin/codex-clipboard
RUN chmod +x /usr/local/bin/codex-clipboard

# sway config
COPY profiles/alpine/overlay-gui/etc/sway/config /etc/sway/config

# cage config
COPY profiles/alpine/overlay-gui/etc/cage/config /etc/cage/config

# udev rules for seatd
COPY profiles/alpine/overlay-gui/etc/udev/rules.d/99-seatd.rules /etc/udev/rules.d/99-seatd.rules

# GUI init service
COPY profiles/alpine/overlay-gui/etc/init.d/codex-gui /etc/init.d/codex-gui
RUN chmod +x /etc/init.d/codex-gui

# ── Install first-boot and helper scripts ────────────────────────────────────
COPY scripts/first-boot.sh /usr/local/bin/first-boot
COPY scripts/setup-codex.sh /usr/local/bin/setup-codex
COPY scripts/cron-codex-update.sh /usr/local/bin/cron-codex-update
RUN chmod +x /usr/local/bin/first-boot /usr/local/bin/setup-codex /usr/local/bin/cron-codex-update

# ── Install shared infrastructure scripts ────────────────────────────────────
COPY shared/network/codex-network-stack.sh /usr/local/sbin/codex-network-stack
COPY shared/network/codex-network-stack.sh /usr/local/bin/codex-network
COPY shared/network/codex-wifi-wizard.sh /usr/local/bin/codex-wifi-wizard.sh
COPY shared/network/codex-wifi-wizard.sh /usr/local/sbin/codex-wifi-wizard
COPY shared/camoufox/install-camoufox.sh /usr/local/sbin/install-camoufox.sh
RUN chmod +x /usr/local/sbin/codex-network-stack /usr/local/bin/codex-network \
    /usr/local/bin/codex-wifi-wizard.sh /usr/local/sbin/codex-wifi-wizard \
    /usr/local/sbin/install-camoufox.sh

# ── Install AGENTS.md ────────────────────────────────────────────────────────
COPY AGENTS.md /workspace/AGENTS.md

# ── Install system configs ───────────────────────────────────────────────────
COPY profiles/alpine/overlay/etc/profile /etc/profile.d/colinux.sh
COPY profiles/alpine/overlay/etc/motd /etc/motd
COPY profiles/alpine/overlay/etc/config/auto-update.conf /persist/config/auto-update.conf
COPY profiles/alpine/overlay/etc/codex-update-crontab /etc/codex-update-crontab

# ── Install OpenRC init scripts ──────────────────────────────────────────────
COPY profiles/alpine/overlay/etc/init.d/ /etc/init.d/

# ── Install user bashrc ─────────────────────────────────────────────────────
COPY profiles/alpine/overlay-gui/home/codex/.bashrc /home/codex/.bashrc
RUN chown codex:codex /home/codex/.bashrc

# ── Create mock codex binary for testing ─────────────────────────────────────
RUN printf '%s\n' \
    '#!/bin/bash' \
    '# CoLinux — Codex CLI placeholder' \
    'VERSION="${CODEX_VERSION:-0.1.0-placeholder}"' \
    'if [ "$1" = "--version" ]; then echo "codex $VERSION (CoLinux Lite GUI placeholder)"; exit 0; fi' \
    'if [ "$1" = "--help" ]; then echo "CoLinux Lite GUI - OpenAI Codex CLI placeholder"; echo "Run: setup-codex --install"; exit 0; fi' \
    'echo "CoLinux Lite GUI - Codex CLI Placeholder"' \
    'echo "To install real Codex binary: setup-codex --install"' \
    'echo "GUI mode: cage + foot + sway available"' \
    'exec bash' \
    > /usr/local/bin/codex && chmod +x /usr/local/bin/codex

# ── Setup entrypoint ─────────────────────────────────────────────────────────
RUN echo "ENABLED=yes" > /etc/default/codex-firstboot 2>/dev/null || true

# ── Seatd setup ──────────────────────────────────────────────────────────────
RUN mkdir -p /run/seatd && chmod 2755 /run/seatd

# ── Create postinstall directory ─────────────────────────────────────────────
RUN mkdir -p /persist/config/postinstall && \
    echo '#!/bin/sh' > /persist/config/postinstall/50-install-camoufox.sh && \
    echo 'if [ ! -d /opt/camoufox/venv ]; then' >> /persist/config/postinstall/50-install-camoufox.sh && \
    echo '    /usr/local/sbin/install-camoufox.sh --edition lite-gui 2>&1' >> /persist/config/postinstall/50-install-camoufox.sh && \
    echo 'fi' >> /persist/config/postinstall/50-install-camoufox.sh && \
    chmod +x /persist/config/postinstall/50-install-camoufox.sh

# ── Syntax validation (fails build if scripts have errors) ───────────────────
RUN echo "=== Validating script syntax ===" && \
    bash -n /usr/local/bin/codex-shell-gui && echo "  ✓ codex-shell-gui" && \
    bash -n /usr/local/bin/codex-clipboard && echo "  ✓ codex-clipboard" && \
    bash -n /usr/local/sbin/codex-network-stack && echo "  ✓ codex-network-stack" && \
    bash -n /usr/local/bin/codex-wifi-wizard.sh && echo "  ✓ codex-wifi-wizard" && \
    bash -n /usr/local/sbin/install-camoufox.sh && echo "  ✓ install-camoufox.sh" && \
    bash -n /usr/local/bin/codex-shell && echo "  ✓ codex-shell" && \
    echo "" && \
    echo "=== Validating configs ===" && \
    test -f /etc/codex-shell.conf && echo "  ✓ /etc/codex-shell.conf" && \
    test -f /etc/sway/config && echo "  ✓ /etc/sway/config" && \
    test -f /etc/cage/config && echo "  ✓ /etc/cage/config" && \
    test -f /etc/udev/rules.d/99-seatd.rules && echo "  ✓ 99-seatd.rules" && \
    test -x /etc/init.d/codex-gui && echo "  ✓ codex-gui init" && \
    echo "" && \
    echo "=== Validating binaries ===" && \
    command -v cage >/dev/null && echo "  ✓ cage $(cage --version 2>/dev/null || echo 'installed')" && \
    command -v sway >/dev/null && echo "  ✓ sway $(sway --version 2>/dev/null | head -1 || echo 'installed')" && \
    command -v foot >/dev/null && echo "  ✓ foot $(foot --version 2>/dev/null || echo 'installed')" && \
    command -v seatd >/dev/null && echo "  ✓ seatd $(seatd --version 2>/dev/null || echo 'installed')" && \
    command -v grim >/dev/null && echo "  ✓ grim" && \
    command -v slurp >/dev/null && echo "  ✓ slurp" && \
    echo "" && \
    echo "=== All validations passed ===" || \
    (echo "ERROR: Script/config validation failed!" && exit 1)

# ── Set working directory ────────────────────────────────────────────────────
WORKDIR /workspace

# ── Entrypoint ───────────────────────────────────────────────────────────────
# Default: run as codex user with bash for interactive testing.
# To test the GUI shell: docker run ... codex-shell-gui
USER codex
ENTRYPOINT ["/bin/bash"]
CMD ["-l"]
