#!/bin/bash
# codex-mount-rw — Mount a block device read-write with serial confirmation
# Part of CoLinux Lite
#
# Usage: codex-mount-rw --confirm SERIAL /dev/sdX1 [--timeout MINUTES]
#
# Safety: The --confirm flag with the correct disk serial number is REQUIRED.
# Additional safety: boot device check, forensic mode check, TTY requirement,
# serial readability check, and auto-remount-ro timeout.
set -euo pipefail


COLINUX_COMMAND="codex-mount-rw"
[[ " $* " == *" --json "* ]] && COLINUX_JSON=true
# shellcheck source=/usr/local/lib/colinux/output.sh
if ! source /usr/local/lib/colinux/output.sh 2>/dev/null; then
    colinux_init_output() { :; }
    colinux_result() { :; }
    colinux_die() { echo "ERROR: $*" >&2; exit 1; }
    colinux_confirm() {
        [[ "${COLINUX_YES:-}" == "true" ]] && return 0
        local _r=""; read -rp "$1 " _r || _r=""; case "${_r,,}" in y|yes) return 0;; *) return 1;; esac
    }
fi

LOG_DIR="/persist/logs"
LOGFILE="${LOG_DIR}/disk-actions.log"
MOUNT_BASE="/mnt/disks"

mkdir -p "$LOG_DIR" "$MOUNT_BASE/by-device" "$MOUNT_BASE/by-label" "$MOUNT_BASE/by-uuid"

log_action() {
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S %Z')"
    echo "[$ts] mount-rw: $*" >> "$LOGFILE"
}

die() {
    log_action "FATAL $*"
    colinux_die "$@"
}

usage() {
    echo "Usage: codex-mount-rw --confirm SERIAL <device> [--timeout MINUTES]"
    echo ""
    echo "Mount a block device read-write at ${MOUNT_BASE}/by-device/<name>"
    echo ""
    echo "WARNING: Read-write mount. You MUST confirm with the disk serial number."
    echo ""
    echo "Options:"
    echo "  --confirm SERIAL  Required. The serial number of the target disk."
    echo "  --noexec          Add noexec flag (default: not set for rw mounts)"
    echo "  --timeout MINUTES Auto-remount read-only after N minutes (default: 15)"
    echo ""
    echo "Examples:"
    echo "  codex-mount-rw --confirm WXYZ12345 /dev/sdb1"
    echo "  codex-mount-rw --confirm WXYZ12345 --noexec /dev/nvme0n1p3"
    echo "  codex-mount-rw --confirm WXYZ12345 --timeout 30 /dev/sdb1"
    exit 1
}

# ── Parse arguments ───────────────────────────────────────────────────────
CONFIRM_SERIAL=""
DEVICE=""
EXTRA_OPTS=""
TIMEOUT_MINUTES="${CODEX_RW_TIMEOUT:-15}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --confirm)
            [[ -z "${2:-}" ]] && die "--confirm requires a serial number argument."
            CONFIRM_SERIAL="$2"
            shift 2
            ;;
        --noexec)
            EXTRA_OPTS+=",noexec"
            shift
            ;;
        --timeout)
            TIMEOUT_MINUTES="${2:?--timeout requires a number}"
            shift 2
            ;;
        --json)
            COLINUX_JSON=true
            shift
            ;;
        --yes|-y)
            COLINUX_YES=true
            shift
            ;;
        --help|-h)
            usage
            ;;
        -*)
            die "Unknown option: $1"
            ;;
        *)
            [[ -n "$DEVICE" ]] && die "Multiple devices specified."
            DEVICE="$1"
            shift
            ;;
    esac
done

colinux_init_output

# ── Validate arguments ────────────────────────────────────────────────────
if [[ -z "$DEVICE" ]]; then
    usage >&2
    die "No device specified."
fi

if [[ -z "$CONFIRM_SERIAL" ]]; then
    die "--confirm SERIAL is required for read-write mounts. Get the serial with: lsblk -d -o NAME,SERIAL /dev/sdX or: codex-disk-inventory"
fi

# ── Require interactive terminal ──────────────────────────────────────────
if [[ ! -t 0 ]]; then
    die "Read-write mounts require an interactive terminal (safety measure)."
fi

if [[ ! -b "$DEVICE" ]]; then
    die "$DEVICE is not a valid block device."
fi

# ── Check if device is the boot device ────────────────────────────────────
BOOT_DEV=""
if [[ -f /proc/cmdline ]]; then
    cmdline_root="$(grep -oE 'root=[^[:space:]]+' /proc/cmdline 2>/dev/null | sed 's/^root=//' || true)"
    if [[ -n "$cmdline_root" ]]; then
        if [[ "$cmdline_root" == /dev/* ]]; then
            BOOT_DEV="${cmdline_root%%[0-9]*}"
            BOOT_DEV="${BOOT_DEV%%p[0-9]*}"
        elif [[ "$cmdline_root" == PARTUUID=* ]]; then
            puuid="${cmdline_root#PARTUUID=}"
            BOOT_DEV="$(blkid -t "PARTUUID=${puuid}" -o device 2>/dev/null | head -1 || true)"
            BOOT_DEV="${BOOT_DEV%%[0-9]*}"
            BOOT_DEV="${BOOT_DEV%%p[0-9]*}"
        fi
    fi
fi
if [[ -z "$BOOT_DEV" ]]; then
    BOOT_DEV="$(findmnt -n -o SOURCE / 2>/dev/null | head -1 || true)"
    BOOT_DEV="${BOOT_DEV%%[0-9]*}"
    BOOT_DEV="${BOOT_DEV%%p[0-9]*}"
fi

# Resolve target device to parent for comparison
PARENT_DEV="$DEVICE"
if [[ "$DEVICE" =~ ^/dev/(nvme[0-9]+n[0-9]+)p[0-9]+$ ]]; then
    PARENT_DEV="/dev/${BASH_REMATCH[1]}"
elif [[ "$DEVICE" =~ ^/dev/([a-z]+)[0-9]+$ ]]; then
    PARENT_DEV="/dev/${BASH_REMATCH[1]}"
elif [[ "$DEVICE" =~ ^/dev/(mmcblk[0-9]+)p[0-9]+$ ]]; then
    PARENT_DEV="/dev/${BASH_REMATCH[1]}"
fi

if [[ -n "$BOOT_DEV" && "$PARENT_DEV" == "$BOOT_DEV" ]]; then
    die "REFUSING to write-mount the boot device ($DEVICE, parent: $PARENT_DEV, boot: $BOOT_DEV). Writing to the boot device can destroy the running system."
fi

# ── Check forensic mode ───────────────────────────────────────────────────
if [[ -f /persist/config/forensic-mode ]]; then
    die "REFUSING write-mount — system is in FORENSIC MODE. Disable forensic mode to allow write mounts."
fi

# ── Retrieve actual disk serial ───────────────────────────────────────────
ACTUAL_SERIAL=""
ACTUAL_SERIAL="$(lsblk -d -n -o SERIAL "$PARENT_DEV" 2>/dev/null | tr -d ' ' || true)"
if [[ -z "$ACTUAL_SERIAL" ]] && command -v hdparm &>/dev/null; then
    ACTUAL_SERIAL="$(hdparm -I "$PARENT_DEV" 2>/dev/null | grep -i 'Serial Number' | awk -F: '{print $2}' | tr -d ' ' || true)"
fi
if [[ -z "$ACTUAL_SERIAL" ]] && [[ -d "/sys/block/${PARENT_DEV##*/}" ]]; then
    ACTUAL_SERIAL="$(cat "/sys/block/${PARENT_DEV##*/}/device/serial" 2>/dev/null | tr -d ' ' || true)"
fi

# Normalize both serials for comparison (trim whitespace, uppercase)
CONFIRM_NORMALIZED="$(echo "$CONFIRM_SERIAL" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]')"
ACTUAL_NORMALIZED="$(echo "$ACTUAL_SERIAL" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]')"

if [[ -z "$ACTUAL_NORMALIZED" ]]; then
    die "Could not read serial number from $PARENT_DEV. Write-mount is REFUSED when serial cannot be verified."
fi

if [[ "$CONFIRM_NORMALIZED" != "$ACTUAL_NORMALIZED" ]]; then
    die "Serial number mismatch! Expected: ${CONFIRM_SERIAL}, Actual: ${ACTUAL_SERIAL}. Refusing to mount."
fi
echo "Serial confirmed: ${ACTUAL_SERIAL}"

DEVNAME="${DEVICE##*/}"
MOUNT_POINT="${MOUNT_BASE}/by-device/${DEVNAME}"

# Check if already mounted
if mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
    echo "Device $DEVICE is already mounted at $MOUNT_POINT" >&2
    log_action "ALREADY_MOUNTED device=$DEVICE mountpoint=$MOUNT_POINT"
    exit 0
fi

# ── Get filesystem info (safe, no eval) ───────────────────────────────────
FS_TYPE="$(blkid -s TYPE -o value "$DEVICE" 2>/dev/null || echo "")"
LABEL="$(blkid -s LABEL -o value "$DEVICE" 2>/dev/null || echo "")"
UUID="$(blkid -s UUID -o value "$DEVICE" 2>/dev/null || echo "")"

if [[ -z "$FS_TYPE" ]]; then
    echo "WARNING: Could not detect filesystem type. Attempting auto..." >&2
    FS_TYPE="auto"
fi

# ── Perform mount ─────────────────────────────────────────────────────────
mkdir -p "$MOUNT_POINT"

MOUNT_OPTS="rw,nosuid,nodev${EXTRA_OPTS}"

if mount -o "$MOUNT_OPTS" "$DEVICE" "$MOUNT_POINT"; then
    CALLER="$(whoami 2>/dev/null || echo 'unknown')"
    echo "Mounted $DEVICE (rw) at $MOUNT_POINT"
    echo "Auto-remount-ro in ${TIMEOUT_MINUTES} minutes. Use 'mount -o remount,ro $MOUNT_POINT' to remount early."
    log_action "OK device=$DEVICE fs=$FS_TYPE mountpoint=$MOUNT_POINT serial=$ACTUAL_SERIAL caller=$CALLER timeout=${TIMEOUT_MINUTES}m"
else
    die "Failed to mount $DEVICE read-write."
fi

# ── Create by-label symlink ───────────────────────────────────────────────
if [[ -n "$LABEL" ]]; then
    local_symlink_path="${MOUNT_BASE}/by-label/${LABEL}"
    [[ -L "$local_symlink_path" ]] && rm -f "$local_symlink_path"
    ln -s "$MOUNT_POINT" "$local_symlink_path"
    echo "  → symlink: by-label/${LABEL}"
fi

# ── Create by-uuid symlink ────────────────────────────────────────────────
if [[ -n "$UUID" ]]; then
    local_symlink_path="${MOUNT_BASE}/by-uuid/${UUID}"
    [[ -L "$local_symlink_path" ]] && rm -f "$local_symlink_path"
    ln -s "$MOUNT_POINT" "$local_symlink_path"
    echo "  → symlink: by-uuid/${UUID}"
fi

# ── Schedule auto-remount-ro ──────────────────────────────────────────────
if [[ "$TIMEOUT_MINUTES" -gt 0 ]]; then
    (
        sleep "$((TIMEOUT_MINUTES * 60))"
        if mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
            mount -o remount,ro "$MOUNT_POINT" 2>/dev/null && {
                log_action "AUTO_REMOUNT_RO device=$DEVICE mountpoint=$MOUNT_POINT timeout=${TIMEOUT_MINUTES}m"
                echo "Auto-remounted $DEVICE read-only (timeout: ${TIMEOUT_MINUTES}m)" >> "$LOGFILE"
            } || true
        fi
    ) &
    echo "  → Auto-remount-ro scheduled: ${TIMEOUT_MINUTES} minutes"
fi

echo "Done."
colinux_result "mounted read-write" "{\"device\":\"$DEVICE\",\"mountpoint\":\"$MOUNT_POINT\",\"fstype\":\"$FS_TYPE\",\"timeout_minutes\":$TIMEOUT_MINUTES}"
