#!/sbin/openrc-run
# /etc/init.d/codex-auto-update
# CoLinux Lite — Codex CLI auto-update service
#
# Sets up a cron job that periodically checks for Codex CLI updates.
# The cron schedule and behavior are controlled by /etc/config/auto-update.conf.
# This service does NOT perform updates itself — it only installs the cron job.

name="codex-auto-update"
description="CoLinux Lite Codex CLI auto-update cron setup"

depend() {
    need localmount
    after codex-firstboot
    after net
    use logger
}

CRON_TAB="/etc/codex-update-crontab"
CRON_FILE="/etc/crontabs/root"
CRON_MARKER_START="# BEGIN CoLinux codex-auto-update"
CRON_MARKER_END="# END CoLinux codex-auto-update"
CONFIG_FILE="/persist/config/auto-update.conf"
UPDATE_SCRIPT="/usr/local/bin/cron-codex-update"
LOG_DIR="/persist/logs"

# Default configuration values (overridden by config file if present)
ENABLED="true"
INTERVAL="6"

config_load() {
    [ -f "${CONFIG_FILE}" ] || return 1
    while IFS='=' read -r key value; do
        case "$key" in
            \#*|"") continue ;;
            enabled) ENABLED="$(echo "$value" | xargs 2>/dev/null)" ;;
            interval) INTERVAL="$(echo "$value" | xargs 2>/dev/null)" ;;
            lock_wait) LOCK_WAIT="$(echo "$value" | xargs 2>/dev/null)" ;;
        esac
    done < "${CONFIG_FILE}"
}

start() {
    config_load

    if [ "${ENABLED}" != "true" ]; then
        einfo "Codex auto-update is disabled in ${CONFIG_FILE}"
        return 0
    fi

    ebegin "Setting up Codex auto-update cron job"

    # Ensure BusyBox crond root crontab and log directory exist
    mkdir -p "$(dirname "${CRON_FILE}")" 2>/dev/null
    touch "${CRON_FILE}"
    mkdir -p "${LOG_DIR}" 2>/dev/null

    # Check that the update script exists
    if [ ! -x "${UPDATE_SCRIPT}" ]; then
        eend 1 "Update script not found: ${UPDATE_SCRIPT}"
        return 1
    fi

    # Install the crontab
    if [ -f "${CRON_TAB}" ]; then
        # Validate interval before writing the managed block. Do not run a broad
        # sed over /etc/crontabs/root; it may contain unrelated hourly jobs.
        case "${INTERVAL}" in
            1|2|3|4|6|8|12|24)
                ;;
            *)
                ewarn "Invalid INTERVAL=${INTERVAL} in ${CONFIG_FILE}, using default (6)"
                INTERVAL="6"
                ;;
        esac

        tmp_cron="$(mktemp)"
        awk -v start="${CRON_MARKER_START}" -v end="${CRON_MARKER_END}" '
            $0 == start { skip=1; next }
            $0 == end { skip=0; next }
            !skip { print }
        ' "${CRON_FILE}" > "${tmp_cron}"
        {
            cat "${tmp_cron}"
            echo "${CRON_MARKER_START}"
            sed "s|^#\?0 \*/[0-9]* \* \* \* |0 */${INTERVAL} * * * |" "${CRON_TAB}"
            echo "${CRON_MARKER_END}"
        } > "${CRON_FILE}"
        rm -f "${tmp_cron}"
        chmod 0600 "${CRON_FILE}"

        eend 0 "Auto-update cron installed (every ${INTERVAL}h)"
    else
        eend 1 "Crontab file not found: ${CRON_TAB}"
    fi
}

stop() {
    ebegin "Removing Codex auto-update cron job"

    if [ -f "${CRON_FILE}" ]; then
        tmp_cron="$(mktemp)"
        awk -v start="${CRON_MARKER_START}" -v end="${CRON_MARKER_END}" '
            $0 == start { skip=1; next }
            $0 == end { skip=0; next }
            !skip { print }
        ' "${CRON_FILE}" > "${tmp_cron}"
        cat "${tmp_cron}" > "${CRON_FILE}"
        rm -f "${tmp_cron}"
        eend 0 "Auto-update cron removed"
    else
        eend 0 "No auto-update cron to remove"
    fi
}

status() {
    config_load

    if [ "${ENABLED}" != "true" ]; then
        einfo "Codex auto-update: disabled"
        return 0
    fi

    if [ -f "${CRON_LINK}" ]; then
        einfo "Codex auto-update: active (every ${INTERVAL}h)"
        einfo "Crontab: ${CRON_LINK}"
    else
        einfo "Codex auto-update: enabled but cron job not installed"
    fi
}
