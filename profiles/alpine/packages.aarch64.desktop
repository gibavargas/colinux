# =============================================================================
# CoLinux Desktop — Alpine aarch64 Package List
# =============================================================================
# Full GNOME desktop experience with Electron Codex Desktop app (aarch64).
# Based on Alpine Linux. Identical to x86_64 desktop minus arch-specific deps.
# =============================================================================

# --- Core system (from lite) ---
alpine-base
linux-lts
linux-firmware
eudev
bash
coreutils
file
iw

# Security & privilege escalation
doas
sudo
polkit

# Terminal & productivity
tmux
git

# Networking
openssh-client-default
curl
wget
ca-certificates

# CLI utilities
jq
yq-go
ripgrep
fd
fzf
nano
python3

# Disk & filesystem tools
util-linux
parted
gptfdisk
e2fsprogs
dosfstools
exfatprogs
ntfs-3g
btrfs-progs
xfsprogs
cryptsetup
lvm2
mdadm

# Storage & hardware utilities
rsync
smartmontools
nvme-cli
hdparm
pciutils
usbutils

# Boot & image tools
xorriso
grub
grub-efi
efibootmgr
# syslinux removed: x86-only, not available on aarch64
mtools
squashfs-tools

# Network management
iwd
wpa_supplicant
dhcpcd

# Compression & crypto
openssl
tar
gzip
xz

# =============================================================================
