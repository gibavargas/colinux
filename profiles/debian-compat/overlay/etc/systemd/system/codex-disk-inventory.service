[Unit]
Description=CodexOS Disk Inventory Scanner
After=local-fs.target codex-firstboot.service
Before=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/codex-disk-inventory
RemainAfterExit=yes
TimeoutStartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
