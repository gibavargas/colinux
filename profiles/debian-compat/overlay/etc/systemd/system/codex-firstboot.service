[Unit]
Description=CoLinux Compat First-Boot Setup
After=network.target network-online.target
Wants=network-online.target
Before=codex-disk-inventory.service codex-auto-update.service
ConditionPathExists=!/persist/.first-boot-done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/first-boot
RemainAfterExit=yes
TimeoutStartSec=300
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
