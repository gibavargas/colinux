#!/usr/bin/env bash
# =============================================================================
# CoLinux Desktop — Update Wrapper
# =============================================================================
# Simplified update entry point. Calls both system and desktop updaters.
#
# Usage:
#   codex-update          # Check and install updates
#   codex-update --check  # Check only, don't install
#   codex-update --force  # Force update even if current
# =============================================================================
set -euo pipefail

CMD="${1:-}"

run_both() {
    local status=0 rc

    set +e
    /usr/local/bin/codex-system-autoupdate "$@" 2>&1
    rc=$?
    if [[ $rc -ne 0 ]]; then
        status=$rc
    fi

    /usr/local/bin/codex-desktop-autoupdate "$@" 2>&1
    rc=$?
    if [[ $status -eq 0 && $rc -ne 0 ]]; then
        status=$rc
    elif [[ $rc -ne 0 && $rc -ne 100 ]]; then
        status=$rc
    fi
    set -e

    return "$status"
}

case "$CMD" in
    --check|-c)
        run_both --check
        ;;
    --force|-f)
        run_both --force
        ;;
    --help|-h)
        echo "Usage: codex-update [--check] [--force]"
        ;;
    "")
        run_both
        ;;
    *)
        echo "Unknown option: $CMD" >&2
        echo "Usage: codex-update [--check] [--force]" >&2
        exit 1
        ;;
esac
