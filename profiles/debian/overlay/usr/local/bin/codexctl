#!/usr/bin/env bash
# =============================================================================
# CodexOS Desktop — Master Control Tool (codexctl)
# =============================================================================
# Central CLI for managing CodexOS Desktop. Mirrors the lite edition's codexctl
# with additions for desktop-specific operations.
#
# Usage:
#   codexctl status          Show system status
#   codexctl update          Trigger update check
#   codexctl update --force  Force update
#   codexctl rollback        Roll back to previous version
#   codexctl setup           Re-run Codex Desktop setup
#   codexctl disks           Show disk inventory
#   codexctl mount-ro DEV    Mount device read-only
#   codexctl backup DEV      Create disk backup
#   codexctl desktop start|stop|restart  Control Codex Desktop app
#   codexctl network list|connect|scan    Network management
#   codexctl logs [service]  Show logs
#   codexctl version         Show versions
#   codexctl help            Show help
# =============================================================================
set -euo pipefail

VERSION="1.0.0"
LOG_DIR="/persist/logs"
STATE_DIR="/var/lib/codex-desktop"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }
info() { echo -e "${BLUE}→${NC} $*"; }

# ── Status ───────────────────────────────────────────────────────────────────
cmd_status() {
    echo "═══ CodexOS Desktop Status ═══"
    echo ""

    # System info
    info "System"
    echo "  Kernel:      $(uname -r)"
    echo "  Hostname:    $(hostname)"
    echo "  Uptime:      $(uptime -p 2>/dev/null || uptime)"
    echo "  Memory:      $(free -h | awk '/Mem:/{print $3"/"$2}')"
    echo ""

    # Codex Desktop
    info "Codex Desktop"
    if [ -x /opt/codex-desktop/codex-desktop ]; then
        ok "Installed: $(readlink -f /opt/codex-desktop/codex-desktop 2>/dev/null || echo '/opt/codex-desktop/codex-desktop')"
        if systemctl is-active --quiet codex-desktop.service 2>/dev/null; then
            ok "Running (systemd service)"
        elif pgrep -f "codex-desktop" >/dev/null 2>&1; then
            ok "Running (process)"
        else
            warn "Not running"
        fi
    else
        warn "Not installed"
    fi
    echo ""

    # Codex CLI
    info "Codex CLI"
    if [ -x /usr/local/bin/codex ]; then
        local ver
        ver="$(/usr/local/bin/codex --version 2>/dev/null || echo 'unknown')"
        ok "v$ver"
    else
        warn "Not found"
    fi
    echo ""

    # Update status
    info "Updates"
    if [ -f /etc/codex-auto-update.conf ]; then
        ok "Configured"
        if systemctl is-enabled --quiet codex-update.timer 2>/dev/null; then
            ok "Timer active"
            local next
            next="$(systemctl show codex-update.timer --property=NextElapseUSec 2>/dev/null | cut -d= -f2 || echo 'unknown')"
            echo "  Next check:  $next"
        else
            warn "Timer not active"
        fi
    else
        warn "No update config"
    fi
    echo ""

    # Network
    info "Network"
    if command -v nmcli >/dev/null 2>&1; then
        nmcli -t -f NAME,TYPE,DEVICE con show --active 2>/dev/null | while IFS=: read -r name type dev; do
            [ -z "$name" ] && continue
            ok "$name ($type) on $dev"
        done
    else
        ip -brief addr show 2>/dev/null | while read -r line; do
            [ -n "$line" ] && ok "$line"
        done
    fi
    echo ""

    # Disks
    info "Disks"
    lsblk -dn -o NAME,SIZE,TYPE,MOUNTPOINT 2>/dev/null | while read -r line; do
        echo "  $line"
    done
    echo ""

    # Persistent storage
    info "Persistent Storage"
    if [ -d /persist ]; then
        local persist_size
        persist_size="$(df -h /persist 2>/dev/null | awk 'NR==2{print $3"/"$2" ("$5")"}' || echo 'unknown')"
        ok "/persist: $persist_size"
    else
        warn "/persist not mounted"
    fi
}

# ── Update ───────────────────────────────────────────────────────────────────
cmd_update() {
    local force=""
    [ "${1:-}" = "--force" ] && force="--force"

    info "Checking for updates..."

    # System updates
    if [ -x /usr/local/bin/codex-system-autoupdate ]; then
        info "Running system update check..."
        /usr/local/bin/codex-system-autoupdate $force 2>&1 || warn "System update had issues"
    fi

    # Codex Desktop updates
    if [ -x /usr/local/bin/codex-desktop-autoupdate ]; then
        info "Running Codex Desktop update check..."
        /usr/local/bin/codex-desktop-autoupdate $force 2>&1 || warn "Codex Desktop update had issues"
    fi

    ok "Update check complete"
}

# ── Rollback ─────────────────────────────────────────────────────────────────
cmd_rollback() {
    if [ -x /usr/local/bin/codex-desktop-autoupdate ]; then
        /usr/local/bin/codex-desktop-autoupdate --rollback
    else
        err "Rollback tool not found"
        exit 1
    fi
}

# ── Setup ────────────────────────────────────────────────────────────────────
cmd_setup() {
    err "Codex Desktop setup is disabled in the production Lite baseline."
}

# ── Disks ────────────────────────────────────────────────────────────────────
cmd_disks() {
    if [ -x /usr/local/bin/codex-disk-inventory ]; then
        /usr/local/bin/codex-disk-inventory --refresh
        echo ""
        cat /persist/state/disk/inventory.txt
    else
        err "Disk inventory tool not found"
        exit 1
    fi
}

# ── Mount read-only ──────────────────────────────────────────────────────────
cmd_mount_ro() {
    local dev="${1:-}"
    if [ -z "$dev" ]; then
        err "Usage: codexctl mount-ro /dev/sdX"
        exit 1
    fi

    if [ -x /usr/local/bin/codex-mount-ro ]; then
        sudo /usr/local/bin/codex-mount-ro "$dev"
    else
        err "Read-only mount wrapper not found"
    fi
}

# ── Backup ───────────────────────────────────────────────────────────────────
cmd_backup() {
    err "Root disk imaging is disabled in the desktop compatibility profile. Use a trusted root console for imaging."
}

# ── Desktop app control ──────────────────────────────────────────────────────
cmd_desktop() {
    local action="${1:-}"
    case "$action" in
        start)
            info "Starting Codex Desktop..."
            systemctl start codex-desktop.service 2>/dev/null || {
                # Fallback: launch directly
                DISPLAY=:0 nohup /opt/codex-desktop/codex-desktop >/dev/null 2>&1 &
                ok "Started (process mode)"
            }
            ;;
        stop)
            info "Stopping Codex Desktop..."
            systemctl stop codex-desktop.service 2>/dev/null || {
                pkill -f "codex-desktop" 2>/dev/null && ok "Stopped" || warn "No process found"
            }
            ;;
        restart)
            cmd_desktop stop
            sleep 1
            cmd_desktop start
            ;;
        status)
            if systemctl is-active --quiet codex-desktop.service 2>/dev/null; then
                ok "Codex Desktop is running"
            else
                warn "Codex Desktop is not running"
            fi
            ;;
        *)
            echo "Usage: codexctl desktop {start|stop|restart|status}"
            exit 1
            ;;
    esac
}

# ── Network ──────────────────────────────────────────────────────────────────
cmd_network() {
    local action="${1:-}"
    local arg="${2:-}"

    if ! command -v nmcli >/dev/null 2>&1; then
        err "NetworkManager (nmcli) not available"
        exit 1
    fi

    case "$action" in
        list)
            echo "═══ Network Connections ═══"
            nmcli -t -f NAME,TYPE,DEVICE,STATE con show 2>/dev/null | tr ':' '\t' | column -t
            echo ""
            echo "═══ Wi-Fi Networks ═══"
            nmcli -t -f SSID,SIGNAL,SECURITY dev wifi list 2>/dev/null | tr ':' '\t' | column -t || true
            ;;
        connect)
            if [ -z "$arg" ]; then
                err "Usage: codexctl network connect SSID"
                exit 1
            fi
            info "Connecting to $arg..."
            nmcli dev wifi connect "$arg" 2>&1 && ok "Connected to $arg" || err "Connection failed"
            ;;
        scan)
            info "Scanning for Wi-Fi networks..."
            nmcli dev wifi rescan 2>/dev/null || true
            sleep 2
            nmcli -t -f SSID,SIGNAL,BARS,SECURITY dev wifi list 2>/dev/null | tr ':' '\t' | column -t
            ;;
        *)
            echo "Usage: codexctl network {list|connect|scan}"
            exit 1
            ;;
    esac
}

# ── Logs ─────────────────────────────────────────────────────────────────────
cmd_logs() {
    local service="${1:-all}"

    case "$service" in
        all)
            echo "═══ Recent System Logs ═══"
            tail -30 "$LOG_DIR/codex-system-autoupdate.log" 2>/dev/null || warn "No system update logs"
            echo ""
            echo "═══ Recent Desktop Logs ═══"
            tail -30 "$LOG_DIR/codex-desktop-autoupdate.log" 2>/dev/null || warn "No desktop update logs"
            echo ""
            echo "═══ Recent First Boot Log ═══"
            tail -30 "$LOG_DIR/first-boot.log" 2>/dev/null || warn "No first boot log"
            ;;
        system|update)
            tail -50 "$LOG_DIR/codex-system-autoupdate.log" 2>/dev/null || warn "No logs"
            ;;
        desktop|app)
            tail -50 "$LOG_DIR/codex-desktop-autoupdate.log" 2>/dev/null || warn "No logs"
            ;;
        firstboot|boot)
            tail -50 "$LOG_DIR/first-boot.log" 2>/dev/null || warn "No logs"
            ;;
        journal)
            journalctl -u codex-update.service -u codex-desktop.service -u codex-firstboot.service \
                --no-pager -n 50 2>/dev/null || warn "No journal entries"
            ;;
        *)
            tail -50 "$LOG_DIR/${service}.log" 2>/dev/null || warn "No logs for '$service'"
            ;;
    esac
}

# ── Version ──────────────────────────────────────────────────────────────────
cmd_version() {
    echo "CodexOS Desktop v$VERSION"
    echo ""

    info "Codex Desktop"
    if [ -f "$STATE_DIR/wrapper-version" ]; then
        echo "  Wrapper:     $(cat "$STATE_DIR/wrapper-version")"
    fi
    if [ -f "$STATE_DIR/current-version" ]; then
        echo "  Codex CLI:   v$(cat "$STATE_DIR/current-version")"
    elif [ -x /usr/local/bin/codex ]; then
        echo "  Codex CLI:   $(/usr/local/bin/codex --version 2>/dev/null || echo 'unknown')"
    fi
    echo ""

    info "System"
    echo "  CodexOS:     codexos-desktop"
    echo "  Base:        Debian $(cat /etc/debian_version 2>/dev/null || echo 'unknown')"
    echo "  Kernel:      $(uname -r)"
}

# ── Help ─────────────────────────────────────────────────────────────────────
cmd_help() {
    cat <<'HELP'
CodexOS Desktop — Control Tool v1.0.0

Usage: codexctl <command> [options]

Commands:
  status                          Show system status overview
  update [--force]                Check/install updates
  rollback                        Roll back to previous version
  setup                           Re-run Codex Desktop setup
  disks                           Show disk inventory
  mount-ro /dev/sdX               Mount device read-only (disk safety)
  desktop start|stop|restart|status  Control Codex Desktop app
  network list|connect|scan       Network/Wi-Fi management
  logs [service|journal]          Show logs
  version                         Show version information
  help                            Show this help

Services:
  codex-desktop.service           Electron Codex Desktop app
  codex-update.timer              Auto-update (4h interval)
  codex-firstboot.service         First boot initialization
  codex-disk-inventory.service    Disk scanner

Disk Safety:
  All disks are mounted read-only by default.
  Use 'codexctl mount-ro' or 'codex-mount-ro' for safe access.
  Create backups from a trusted root console before any write operations.
HELP
}

# ── Main ─────────────────────────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)   cmd_status ;;
        update)   cmd_update "$@" ;;
        rollback) cmd_rollback ;;
        setup)    cmd_setup ;;
        disks)    cmd_disks ;;
        mount-ro) cmd_mount_ro "$@" ;;
        backup)   cmd_backup "$@" ;;
        desktop)  cmd_desktop "$@" ;;
        network)  cmd_network "$@" ;;
        logs)     cmd_logs "$@" ;;
        version)  cmd_version ;;
        help|--help|-h) cmd_help ;;
        *)
            err "Unknown command: $cmd"
            echo "Run 'codexctl help' for available commands"
            exit 1
            ;;
    esac
}

main "$@"
