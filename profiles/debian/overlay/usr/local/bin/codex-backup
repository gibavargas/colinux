#!/usr/bin/env bash
# =============================================================================
# CodexOS Desktop — Disk Backup Tool
# =============================================================================
# Creates a backup image of a block device. Safety feature: warns about write
# operations and creates verified backups.
#
# Usage:
#   codex-backup /dev/sdX                     # Backup to /persist/backups/
#   codex-backup /dev/sdX /path/to/output.img # Custom output path
#   codex-backup --verify /path/to/image.img   # Verify a backup
# =============================================================================
set -euo pipefail

DEV="${1:-}"
DEST="${2:-}"
VERIFY_ONLY=false

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}✗${NC} $*" >&2; exit 1; }
ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }

[ "${1:-}" = "--verify" ] && { VERIFY_ONLY=true; DEV="${2:-}"; shift; }

# ── Verify backup ────────────────────────────────────────────────────────────
if $VERIFY_ONLY; then
    if [ -z "$DEV" ]; then
        echo "Usage: codex-backup --verify /path/to/image.img"
        exit 1
    fi

    [ ! -f "$DEV" ] && err "File not found: $DEV"

    echo "Verifying backup: $DEV"
    echo "  Size: $(du -h "$DEV" | cut -f1)"

    if command -v md5sum >/dev/null 2>&1 && [ -f "${DEV}.md5" ]; then
        echo "  Checking MD5..."
        if md5sum -c "${DEV}.md5" >/dev/null 2>&1; then
            ok "MD5 verification passed"
        else
            err "MD5 verification FAILED"
        fi
    else
        echo "  Generating MD5..."
        md5sum "$DEV" > "${DEV}.md5"
        ok "MD5 created: ${DEV}.md5"
    fi
    exit 0
fi

# ── Backup ───────────────────────────────────────────────────────────────────
if [ -z "$DEV" ]; then
    echo "Usage: codex-backup /dev/sdX [output.img]"
    echo ""
    echo "⚠  WARNING: This creates a full disk image backup."
    echo "   Ensure you have enough disk space."
    echo ""
    echo "Available devices:"
    lsblk -lnpo NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null
    exit 1
fi

[ ! -b "$DEV" ] && err "Not a block device: $DEV"

# Check if mounted
if findmnt -rn -o TARGET -S "$DEV" >/dev/null 2>&1; then
    err "Device $DEV is currently mounted! Unmount first: sudo umount $DEV"
fi

# Determine output path
if [ -n "$DEST" ]; then
    OUTPUT="$DEST"
else
    mkdir -p /persist/backups
    OUTPUT="/persist/backups/$(basename "$DEV")-$(date +%Y%m%d-%H%M%S).img"
fi

# Check space
DEV_SIZE_BYTES=$(blockdev --getsize64 "$DEV" 2>/dev/null || stat -c%s "$DEV")
DEV_SIZE_GB=$((DEV_SIZE_BYTES / 1073741824))
AVAIL_GB=$(df -BG --output=avail "$(dirname "$OUTPUT")" 2>/dev/null | tail -1 | tr -d 'G ')

echo "╔══════════════════════════════════════╗"
echo "║     CodexOS Disk Backup              ║"
echo "╠══════════════════════════════════════╣"
echo "║ Device:  $(printf '%-27s' "$DEV")║"
echo "║ Size:    $(printf '%-6s' "${DEV_SIZE_GB}G")                      ║"
echo "║ Output:  $(printf '%-27s' "$(basename "$OUTPUT")")║"
echo "║ Avail:   $(printf '%-6s' "${AVAIL_GB}G")                      ║"
echo "╚══════════════════════════════════════╝"
echo ""

if [ "$AVAIL_GB" -lt "$DEV_SIZE_GB" ]; then
    warn "Warning: Available space ($AVAIL_GB GB) may be insufficient for ${DEV_SIZE_GB} GB device"
    read -p "Continue with compression? [y/N] " -r
    [[ ! "$REPLY" =~ ^[Yy]$ ]] && exit 0
    COMPRESS=true
else
    COMPRESS=false
fi

# Create backup
if $COMPRESS; then
    echo "Creating compressed backup..."
    dd if="$DEV" bs=4M status=progress 2>&1 | gzip -1 > "${OUTPUT}.gz"
    ln -sf "${OUTPUT}.gz" "$OUTPUT"
    ok "Backup created: ${OUTPUT}.gz"
else
    echo "Creating raw backup..."
    dd if="$DEV" of="$OUTPUT" bs=4M status=progress conv=fsync
    ok "Backup created: $OUTPUT"
fi

# Generate checksum
echo "Generating checksum..."
md5sum "${OUTPUT%.gz}.gz" > "${OUTPUT}.md5" 2>/dev/null || md5sum "$OUTPUT" > "${OUTPUT}.md5"
ok "Checksum: ${OUTPUT}.md5"

echo ""
echo "To verify: codex-backup --verify $OUTPUT"
echo "To restore: sudo dd if=$OUTPUT of=$DEV bs=4M status=progress"
