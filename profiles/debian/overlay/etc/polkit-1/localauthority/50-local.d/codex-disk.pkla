# /etc/polkit-1/localauthority/50-local.d/codex-disk.pkla
# CodexOS Desktop — Polkit rules for disk operations
# The desktop/compat edition must not bypass CodexOS disk wrappers. GUI disk
# managers therefore require administrator authentication instead of granting the
# codex user broad udisks2 privileges.

[codex-disk-mount-readonly]
Identity=unix-user:codex
Action=org.freedesktop.udisks2.filesystem-mount-system;org.freedesktop.udisks2.filesystem-mount
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep

[codex-disk-unmount]
Identity=unix-user:codex
Action=org.freedesktop.udisks2.filesystem-unmount-others
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep

[codex-disk-eject]
Identity=unix-user:codex
Action=org.freedesktop.udisks2.eject-media;org.freedesktop.udisks2.power-off-drive
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep

[codex-smart-data]
Identity=unix-user:codex
Action=org.freedesktop.udisks2.ata-smart-update;org.freedesktop.udisks2.ata-smart-selftest
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep

[codex-network-manager]
Identity=unix-user:codex
Action=org.freedesktop.NetworkManager.*
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep

[codex-system-update]
Identity=unix-user:codex
Action=org.freedesktop.packagekit.system-update
ResultAny=auth_admin
ResultInactive=auth_admin
ResultActive=auth_admin_keep
