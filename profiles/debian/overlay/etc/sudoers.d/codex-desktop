# CodexOS Desktop — Sudoers configuration for codex user
# Provides passwordless access to disk operations, network, and updates.
# Installed to: /etc/sudoers.d/codex-desktop

# Disk operations (wrapper-only safety model)
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-mount-ro
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-disk-inventory

# System updates
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-system-autoupdate
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-desktop-autoupdate
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-update

# Network (via NetworkManager)
codex ALL=(root) NOPASSWD: /usr/local/bin/codex-net-watchdog

# Codex Desktop management
codex ALL=(root) NOPASSWD: /usr/bin/systemctl restart codex-desktop.service
codex ALL=(root) NOPASSWD: /usr/bin/systemctl stop codex-desktop.service
codex ALL=(root) NOPASSWD: /usr/bin/systemctl start codex-desktop.service
