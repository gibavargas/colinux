# =============================================================================
# CodexOS Desktop — Debian Package List
# =============================================================================
# Packages for the codexos-desktop edition.
# Based on Debian 12 (bookworm) with XFCE4 desktop and Electron Codex app.
#
# Organized by category. Comments explain why each package is included.
# =============================================================================

# --- Base System ---
debian-standard
initramfs-tools
systemd
systemd-sysv
dbus
locales
keyboard-configuration
console-setup

# --- Boot & Firmware ---
linux-image-amd64
linux-headers-amd64
grub-efi-amd64
grub-pc-bin
efibootmgr
shim-signed
linux-firmware
firmware-linux-nonfree
firmware-linux-free

# --- XFCE4 Desktop Environment ---
xfce4
xfce4-goodies
xfce4-terminal
xfce4-whiskermenu-plugin
xfce4-notifyd
xfce4-taskmanager
thunar-archive-plugin
thunar-media-tags-plugin
ristretto                     # Image viewer
mousepad                      # Text editor

# --- Display Manager (autologin) ---
lightdm
lightdm-gtk-greeter

# --- Networking ---
network-manager
network-manager-gnome
network-manager-openvpn
network-manager-vpnc
modemmanager
mobile-broadband-provider-info
wpasupplicant
wireless-tools
iw
openssh-client
openssh-server
curl
wget
ca-certificates
gnutls-bin
rsync

# --- Web Browser (for Codex auth + general use) ---
firefox-esr

# --- Node.js & Electron Runtime ---
