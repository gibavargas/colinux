# CoLinux Desktop — Development & Testing Container
# Simulates the Alpine-based CoLinux Desktop environment (GNOME + Electron)
# Note: Cannot run GNOME in Docker, but validates scripts and package install.
# Usage: docker build -t colinux-desktop -f Dockerfile-desktop . && docker run -it colinux-desktop

FROM alpine:3.21

LABEL maintainer="CoLinux Project"
LABEL description="CoLinux Desktop (Alpine + GNOME + Electron) test environment"
LABEL version="0.1.0"

# Install all packages from the desktop edition (minus GNOME-specific display deps)
RUN apk add --no-cache \
    alpine-base \
    linux-lts-doc \
    bash \
    coreutils \
    util-linux \
    eudev \
    doas \
    sudo \
    polkit \
    tmux \
    git \
    openssh-client-default \
    curl \
    wget \
    ca-certificates \
    jq \
    yq-go \
    ripgrep \
    fd \
    fzf \
    nano \
    python3 \
    parted \
    gptfdisk \
    e2fsprogs \
    dosfstools \
    exfatprogs \
    btrfs-progs \
    xfsprogs \
    cryptsetup \
    lvm2 \
    mdadm \
    rsync \
    smartmontools \
    pciutils \
    usbutils \
    file \
    iw \
    openssl \
    tar \
    gzip \
    xz \
    shadow \
    procps \
    nodejs \
    npm \
    nss \
    at-spi2-core \
    libnotify \
    xdg-utils \
    dbus \
    sassc \
    dialog

# Install Electron build deps
RUN apk add --no-cache \
    gtk+3.0 \
    libsecret \
    linux-pam \
    2>/dev/null || true

# Create runtime directories
RUN mkdir -p /run/codex \
    /persist/config \
    /persist/data \
    /persist/logs \
    /persist/backups \
    /persist/ssh \
    /persist/state \
    /workspace \
    /mnt/disks/by-label \
    /mnt/disks/by-uuid \
    /mnt/disks/by-device \
    /var/cache/apk \
    /var/lib/colinux \
    /usr/local/lib/colinux \
    /opt/codex-desktop/config \
    /etc/gdm \
    /etc/dconf/profile \
    /etc/dconf/db \
    /etc/xdg/autostart \
    /home/codex/.local/share/gnome-shell/extensions \
    /etc/periodic/6h

RUN mkdir -p /home/codex/.config && touch /home/codex/.config/gnome-initial-setup-done
RUN adduser -D -s /bin/bash -h /home/codex codex && \
    echo "codex ALL=(root) NOPASSWD: /usr/local/bin/codex-disk-inventory, /usr/local/bin/codex-network, /usr/local/bin/codex-backup, /usr/local/bin/codex-restore, /usr/local/bin/codex-update, /usr/local/bin/codexctl, /usr/local/bin/codex-logs, /usr/local/bin/codex-mount-rw, /usr/local/bin/codex-mount-ro, /usr/local/bin/codex-usb-persist" > /etc/sudoers.d/codex && \
    chown -R codex:codex /home/codex /workspace /persist

# Install doas config
COPY profiles/alpine/overlay/etc/doas.conf /etc/doas.conf
RUN chmod 640 /etc/doas.conf

# Install all codex-* tools from both lite and desktop overlays
COPY profiles/alpine/overlay/usr/local/bin/ /usr/local/bin/
COPY profiles/alpine/overlay-desktop/usr/local/bin/ /usr/local/bin/
RUN chmod +x /usr/local/bin/codex-* 2>/dev/null || true

# Install first-boot, setup-codex, cron-update, and electron setup scripts
COPY scripts/first-boot.sh /usr/local/bin/first-boot
COPY scripts/setup-codex.sh /usr/local/bin/setup-codex
COPY scripts/cron-codex-update.sh /usr/local/bin/cron-codex-update
COPY scripts/setup-electron-codex.sh /usr/local/bin/setup-electron-codex
RUN chmod +x /usr/local/bin/first-boot \
    /usr/local/bin/setup-codex \
    /usr/local/bin/cron-codex-update \
    /usr/local/bin/setup-electron-codex

# Install AGENTS.md
COPY AGENTS.md /workspace/AGENTS.md

# Install desktop configs
COPY profiles/alpine/overlay-desktop/etc/gdm/custom.conf /etc/gdm/custom.conf
COPY profiles/alpine/overlay-desktop/etc/NetworkManager/NetworkManager.conf /etc/NetworkManager/NetworkManager.conf
COPY profiles/alpine/overlay-desktop/etc/dconf/profile/user /etc/dconf/profile/user
COPY profiles/alpine/overlay-desktop/etc/dconf/db/local-defaults /etc/dconf/db/local-defaults
COPY profiles/alpine/overlay-desktop/etc/xdg/autostart/codex-desktop-autostart.desktop /etc/xdg/autostart/codex-desktop-autostart.desktop

# Install OpenRC init scripts from desktop overlay
COPY profiles/alpine/overlay-desktop/etc/init.d/ /etc/init.d/
RUN chmod +x /etc/init.d/codex-* 2>/dev/null || true

# Install system configs
COPY profiles/alpine/overlay/etc/profile /etc/profile.d/colinux.sh
COPY profiles/alpine/overlay/etc/motd /etc/motd
COPY profiles/alpine/overlay/etc/config/auto-update.conf /persist/config/auto-update.conf

# Install home directory configs
COPY profiles/alpine/overlay/home/codex/.profile /home/codex/.profile
COPY profiles/alpine/overlay-gui/home/codex/.bashrc /home/codex/.bashrc
RUN chown -R codex:codex /home/codex

# Create mock codex binary for testing
RUN printf '%s\n' \
    '#!/bin/bash' \
    '# CoLinux — Codex CLI placeholder (desktop edition)' \
    'VERSION="${CODEX_VERSION:-0.1.0-placeholder}"' \
    'if [ "$1" = "--version" ]; then echo "codex $VERSION (CoLinux Desktop placeholder)"; exit 0; fi' \
    'if [ "$1" = "--help" ]; then echo "CoLinux Desktop - OpenAI Codex CLI placeholder"; echo "Run: setup-codex --install"; exit 0; fi' \
    'echo "CoLinux Desktop - Codex CLI Placeholder"' \
    'echo "To install real Codex binary: setup-codex --install"' \
    'exec bash' \
    > /usr/local/bin/codex && chmod +x /usr/local/bin/codex

# Set working directory
WORKDIR /workspace

# Set environment
ENV CODEX_EDITION=desktop
ENV CODEX_HOME=/home/codex
ENV CODEX_WORKSPACE=/workspace
ENV CODEX_PERSIST=/persist
ENV CODEX_CONFIG=/persist/config
ENV CODEX_LOGS=/persist/logs

# Copy and run setup-electron-codex.sh (non-interactive, minimal)
RUN /usr/local/bin/setup-electron-codex.sh --install 2>/dev/null || echo "Electron setup skipped in container"

# Setup entrypoint — run as codex user, launch codex-shell-desktop (or bash fallback)
USER codex
ENTRYPOINT ["/bin/bash"]
